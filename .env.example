# Models and AI guidance live in ./config:
#   config/models/<name>.json  -> one tool per file, named after the slugified file name
#                                  shape: { "model": "<deployed id>", "description"?, "baseUrl"?, "apiKey"? }
#                                  baseUrl/apiKey fall back to the defaults below.
#                                  New/changed files are picked up per-request — no restart needed.
#   config/description.md      -> optional; served as MCP `instructions` to guide the calling AI.

# Optional default endpoint root for models without a baseUrl — any
# OpenAI-Responses-compatible endpoint (a LiteLLM proxy, Azure OpenAI/Foundry, etc.).
# The SDK appends /responses to this URL. Use the full API root:
#   OpenAI  -> https://api.openai.com/v1
#   Azure   -> https://<resource>.openai.azure.com/openai/v1
#   LiteLLM -> plain proxy root, e.g. http://localhost:4000
DEFAULT_BASE_URL=https://your-gateway.example.com

# Optional default API key for models without an apiKey. Kept server-side only.
DEFAULT_API_KEY=sk-your-key

# HTTP transport bind address + port (ignored by stdio transport).
# Default 127.0.0.1 (localhost only). Set 0.0.0.0 to expose — then also set
# ALLOWED_HOSTS (comma-separated hostnames) for DNS-rebinding protection.
HOST=127.0.0.1
# ALLOWED_HOSTS=legion.example.com
PORT=5000

# Max discussion rounds the quorum tool will accept (default 5).
MAX_ROUNDS=5

# Allow the calling AI to define ad-hoc quorum roles inline (default true).
# Set false to restrict roles to files in config/roles/.
DYNAMIC_ROLES=true

# Log level: debug | info | warn | error. Default: info.
LOG_LEVEL=info
